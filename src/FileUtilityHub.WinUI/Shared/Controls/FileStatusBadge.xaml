<UserControl
    x:Class="FileUtilityHub_WinUI.Shared.Controls.FileStatusBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <!-- Processing ring (visible only when processing) -->
        <ProgressRing x:Name="ProcessingRing" IsActive="False" Width="16" Height="16" />
        
        <!-- Status icon -->
        <FontIcon x:Name="StatusIcon" FontSize="14" />
        
        <!-- Status text -->
        <TextBlock x:Name="StatusText" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
    </StackPanel>
</UserControl>
