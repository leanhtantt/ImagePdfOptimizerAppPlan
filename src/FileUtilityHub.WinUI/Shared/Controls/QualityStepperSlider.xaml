<UserControl
    x:Class="FileUtilityHub_WinUI.Shared.Controls.QualityStepperSlider"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Spacing="8">
        <!-- Label row: Low label — High label -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{x:Bind LowLabel, Mode=OneWay}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="1" Text="{x:Bind DisplayValue, Mode=OneWay}"
                       Style="{ThemeResource BodyStrongTextBlockStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="{x:Bind HighLabel, Mode=OneWay}"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Right" />
        </Grid>

        <!-- Slider + stepper buttons -->
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="−" Width="32" Height="32" Padding="0"
                    Click="OnDecrementClick"
                    ToolTipService.ToolTip="Giảm giá trị" />

            <Slider Grid.Column="1"
                    x:Name="QualitySlider"
                    Minimum="{x:Bind Minimum, Mode=OneWay}"
                    Maximum="{x:Bind Maximum, Mode=OneWay}"
                    Value="{x:Bind Value, Mode=TwoWay}"
                    StepFrequency="{x:Bind StepFrequency, Mode=OneWay}"
                    SnapsTo="StepValues" />

            <Button Grid.Column="2" Content="+" Width="32" Height="32" Padding="0"
                    Click="OnIncrementClick"
                    ToolTipService.ToolTip="Tăng giá trị" />

            <NumberBox Grid.Column="3" Width="80"
                       Value="{x:Bind Value, Mode=TwoWay}"
                       Minimum="{x:Bind Minimum, Mode=OneWay}"
                       Maximum="{x:Bind Maximum, Mode=OneWay}"
                       SpinButtonPlacementMode="Hidden"
                       SmallChange="{x:Bind StepFrequency, Mode=OneWay}" />
        </Grid>
    </StackPanel>
</UserControl>
