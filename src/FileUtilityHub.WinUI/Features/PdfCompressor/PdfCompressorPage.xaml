<Page
    x:Class="FileUtilityHub_WinUI.Features.PdfCompressor.PdfCompressorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FileUtilityHub_WinUI.Core.Models"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Toolbar -->
            <RowDefinition Height="Auto" /> <!-- InfoBar placeholder -->
            <RowDefinition Height="*" />    <!-- Main Workspace -->
        </Grid.RowDefinitions>

        <!-- 1. Toolbar -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left">
            <AppBarButton Icon="OpenFile" Label="Mở PDF" Command="{x:Bind ViewModel.OpenFileCommand}" />
            <AppBarSeparator />
            <AppBarButton Icon="SelectAll" Label="Chọn tất cả" Command="{x:Bind ViewModel.SelectAllCommand}" IsEnabled="{x:Bind ViewModel.HasFile, Mode=OneWay}" />
            <AppBarButton Icon="ClearSelection" Label="Bỏ chọn" Command="{x:Bind ViewModel.ClearSelectionCommand}" IsEnabled="{x:Bind ViewModel.HasFile, Mode=OneWay}" />
            <AppBarButton Icon="Filter" Label="Áp dụng trang" Command="{x:Bind ViewModel.ApplyPageRangeCommand}" IsEnabled="{x:Bind ViewModel.HasFile, Mode=OneWay}" />
            <AppBarSeparator />
            <AppBarButton Icon="Save" Label="Nén bản mới" Command="{x:Bind ViewModel.CompressCommand}" IsEnabled="{x:Bind ViewModel.HasFile, Mode=OneWay}" />
            <AppBarButton Icon="Folder" Label="Mở thư mục" Command="{x:Bind ViewModel.OpenFolderCommand}" IsEnabled="{x:Bind ViewModel.HasFile, Mode=OneWay}" />
        </CommandBar>

        <!-- 2. Workspace Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- Left: Vertical Thumbnail Rail -->
            <Grid Grid.Column="0" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,1,1" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                <ListView x:Name="ThumbnailList" ItemsSource="{x:Bind ViewModel.Pages}" SelectedItem="{x:Bind ViewModel.SelectedPreviewPage, Mode=TwoWay}" SelectionMode="Single" IsItemClickEnabled="True" ItemClick="ThumbnailList_ItemClick" Visibility="{x:Bind ViewModel.HasFile, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:PdfPageItem">
                            <StackPanel Margin="0,8,0,8">
                                <Grid Background="{ThemeResource LayerFillColorAltBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                                    <Image Source="{x:Bind ThumbnailPath, Mode=OneWay}" Stretch="Uniform" Margin="4"/>
                                    <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="4" />
                                </Grid>
                                <TextBlock Text="{x:Bind DisplayPageNumber, Mode=OneWay}" HorizontalAlignment="Center" Margin="0,4,0,0" Style="{ThemeResource CaptionTextBlockStyle}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Center: Full PDF Preview Scroll -->
            <Grid Grid.Column="1" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,1,1" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                <TextBlock Text="Mở file PDF để xem trước" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorDisabledBrush}" 
                           Visibility="{x:Bind ViewModel.HasFile, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                
                <ScrollViewer x:Name="MainScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Visibility="{x:Bind ViewModel.HasFile, Mode=OneWay}">
                    <ItemsControl x:Name="MainItemsControl" ItemsSource="{x:Bind ViewModel.Pages}" Margin="16">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:PdfPageItem">
                                <Grid Margin="0,0,0,24">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Image Grid.Row="0" Source="{x:Bind PreviewImagePath, Mode=OneWay}" Stretch="Uniform" HorizontalAlignment="Center" MaxWidth="1000" />
                                    <Border Grid.Row="1" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" HorizontalAlignment="Center" Margin="0,8,0,0" Padding="12,4" CornerRadius="4">
                                        <TextBlock Text="{x:Bind DisplayPageNumber, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Right: Settings Panel -->
            <Border Grid.Column="2" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,1">
                <ScrollViewer Padding="20">
                    <StackPanel Spacing="24">
                        <!-- Header -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Thiết lập Nén PDF" Style="{ThemeResource TitleTextBlockStyle}"/>
                            <TextBlock Text="Chỉ nén các trang được chọn. Các trang còn lại sẽ được copy gốc nguyên vẹn." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Card: Page Range -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Nhập Range Chọn" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Ví dụ: 1-5, 8, 20" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{x:Bind ViewModel.PageRangeInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" PlaceholderText="1-5, 8, 20" Margin="0,0,8,0" />
                                    <Button Grid.Column="1" Content="Áp dụng" Command="{x:Bind ViewModel.ApplyPageRangeCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Card: DPI -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Độ phân giải (DPI)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="DPI cao hơn = sắc nét hơn nhưng file nặng hơn." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                <Slider Value="{x:Bind ViewModel.Settings.Dpi, Mode=TwoWay}"
                                        Minimum="100" Maximum="400" StepFrequency="10"
                                        TickFrequency="50" TickPlacement="Outside" />
                                <TextBlock Text="{x:Bind ViewModel.Settings.Dpi, Mode=OneWay}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Card: JPEG Quality -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Chất lượng JPEG (10-80)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <Slider Value="{x:Bind ViewModel.Settings.JpegQuality, Mode=TwoWay}"
                                        Minimum="10" Maximum="80" StepFrequency="1"
                                        TickFrequency="10" TickPlacement="Outside" />
                                <TextBlock Text="{x:Bind ViewModel.Settings.JpegQuality, Mode=OneWay}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Card: Color Mode -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Chế độ màu" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <ComboBox SelectedIndex="0" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Màu (RGB)" />
                                    <ComboBoxItem Content="Trắng đen (Grayscale)" IsEnabled="False" />
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Card: Version History -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Visibility="{x:Bind ViewModel.HasFile, Mode=OneWay}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Lịch sử phiên bản" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <ListView ItemsSource="{x:Bind ViewModel.VersionHistory}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:PdfCompressionVersion">
                                            <Grid Margin="0,4" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{x:Bind DisplayTime}" Style="{ThemeResource BodyTextBlockStyle}" />
                                                    <TextBlock Text="{x:Bind SettingsSummary}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{x:Bind FormattedSize}" VerticalAlignment="Center" Style="{ThemeResource BodyTextBlockStyle}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
