<Page
    x:Class="FileUtilityHub_WinUI.Features.FileMerger.FileMergerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FileUtilityHub_WinUI.Core.Models"
    xmlns:shared="using:FileUtilityHub_WinUI.Shared.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Toolbar -->
            <RowDefinition Height="Auto" /> <!-- InfoBar -->
            <RowDefinition Height="*" />    <!-- Main Workspace -->
        </Grid.RowDefinitions>

        <!-- 1. Toolbar -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left">
            <AppBarButton Icon="Add" Label="Thêm File" Command="{x:Bind ViewModel.AddFilesCommand}"/>
            <AppBarButton Icon="Folder" Label="Import Folder" Command="{x:Bind ViewModel.ChooseFolderCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Delete" Label="Xóa Đã Chọn" Click="OnRemoveSelectedClick"/>
            <AppBarButton Icon="Clear" Label="Xóa Tất Cả" Command="{x:Bind ViewModel.ClearAllCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="OpenLocal" Label="Mở Thư Mục Đích" Command="{x:Bind ViewModel.OpenOutputCommand}"/>
        </CommandBar>

        <!-- 2. Warning/Error InfoBar -->
        <InfoBar Grid.Row="1"
                 Title="{x:Bind ViewModel.WarningTitle, Mode=OneWay}"
                 Message="{x:Bind ViewModel.WarningMessage, Mode=OneWay}"
                 Severity="{x:Bind ViewModel.WarningSeverity, Mode=OneWay, Converter={StaticResource SeverityToInfoBarConverter}}"
                 IsOpen="{x:Bind ViewModel.HasActiveWarning, Mode=OneWay}"
                 IsClosable="True" />

        <!-- 3. Workspace Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- File List with reorder support -->
            <Grid Grid.Column="0" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,1,1" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

                <ListView x:Name="FileList" ItemsSource="{x:Bind ViewModel.MergeItems, Mode=OneWay}" SelectionMode="Extended"
                          CanReorderItems="True" AllowDrop="True"
                          SelectionChanged="FileList_SelectionChanged"
                          DragItemsCompleted="FileList_DragItemsCompleted"
                          Visibility="{x:Bind ViewModel.HasFiles, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="MinHeight" Value="56" />
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:MergeFileItem">
                            <Grid Padding="12,8" ColumnSpacing="12" Background="Transparent" DoubleTapped="FileListItem_DoubleTapped">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Mở file" Icon="OpenFile" Click="MenuFlyoutItem_Open_Click" />
                                        <MenuFlyoutItem Text="Mở thư mục" Icon="Folder" Click="MenuFlyoutItem_OpenFolder_Click" />
                                        <MenuFlyoutItem Text="Xóa khỏi danh sách" Icon="Delete" Click="MenuFlyoutItem_Remove_Click" />
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36" />  <!-- Order number -->
                                    <ColumnDefinition Width="Auto" /> <!-- Thumbnail -->
                                    <ColumnDefinition Width="*" />    <!-- Name -->
                                    <ColumnDefinition Width="100" />  <!-- Size -->
                                    <ColumnDefinition Width="Auto" /> <!-- Status badge -->
                                </Grid.ColumnDefinitions>

                                <!-- Order number -->
                                <TextBlock Grid.Column="0" Text="{x:Bind OrderIndex, Mode=OneWay}"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />

                                <!-- Thumbnail placeholder -->
                                <Border Grid.Column="1" Width="40" Height="40" CornerRadius="6"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <FontIcon Glyph="&#xE8B9;" FontSize="18"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Border>

                                <!-- File name -->
                                <TextBlock Grid.Column="2" Text="{x:Bind FileName}"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Size -->
                                <TextBlock Grid.Column="3" Text="{x:Bind FormattedSize}"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />

                                <!-- Status Badge (shared control) -->
                                <shared:FileStatusBadge Grid.Column="4"
                                                         Status="{x:Bind Status, Mode=OneWay}"
                                                         StatusLabel="{x:Bind StatusDisplay, Mode=OneWay}"
                                                         VerticalAlignment="Center"
                                                         MinWidth="100" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- DropZone empty state -->
                <shared:DropZoneControl Visibility="{x:Bind ViewModel.HasFiles, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                         DropCommand="{x:Bind ViewModel.HandleDropCommand}" />
            </Grid>

            <!-- Settings Panel -->
            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,1">
                <ScrollViewer Padding="20">
                    <StackPanel Spacing="24">
                        <!-- Header -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Thiết lập gộp Tài liệu" Style="{ThemeResource TitleTextBlockStyle}"/>
                            <TextBlock Text="Cấu hình chế độ render, chất lượng và định dạng đầu ra." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- IMAGE ONLY PANEL -->
                        <StackPanel Spacing="24" Visibility="{x:Bind ViewModel.IsImageOnly, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <!-- Card: Page Mode -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Chế độ trang" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="Kích thước trang PDF cho mỗi ảnh." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    <ComboBox SelectedIndex="{x:Bind ViewModel.PageModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Theo kích thước ảnh" />
                                        <ComboBoxItem Content="A4 phủ đầy trang" />
                                        <ComboBoxItem Content="A4 vừa khung (giữ tỷ lệ)" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>

                            <!-- Card: JPEG QScale -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="JPEG QScale ghi đè (0-31)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="Giá trị 0 = tự động theo Chất lượng đã chọn. Giá trị thấp = chất lượng cao hơn." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    <shared:QualityStepperSlider
                                        Value="{x:Bind ViewModel.JpegQScale, Mode=TwoWay}"
                                        Minimum="0" Maximum="31" StepFrequency="1"
                                        LowLabel="Auto" HighLabel="Nén mạnh" />
                                </StackPanel>
                            </Border>

                            <!-- Card: Resolution -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Resize cạnh dài" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="Thu nhỏ ảnh trước khi nhúng vào PDF." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    <ComboBox SelectedIndex="{x:Bind ViewModel.ResolutionIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                        <ComboBoxItem Content="Giữ nguyên gốc" />
                                        <ComboBoxItem Content="1920 px" />
                                        <ComboBoxItem Content="2048 px" />
                                        <ComboBoxItem Content="2560 px" />
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- SCANNED DOCUMENTS PANEL (PDF/OFFICE) -->
                        <StackPanel Spacing="24" Visibility="{x:Bind ViewModel.IsScannedDocument, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <InfoBar Severity="Informational" IsOpen="True" IsClosable="False"
                                     Title="Chế độ Scanned PDF"
                                     Message="Mặc định giữ nguyên trang PDF để không tăng dung lượng hoặc giảm chất lượng. Tắt lựa chọn bên dưới chỉ khi cần rasterize tài liệu." />

                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <CheckBox Content="Giữ nguyên chất lượng và cấu trúc trang PDF"
                                              IsChecked="{x:Bind ViewModel.PreservePdfPages, Mode=TwoWay}" />
                                    <TextBlock Text="Khuyên dùng khi chỉ cần gộp PDF. DPI và chất lượng JPEG chỉ áp dụng khi tắt lựa chọn này."
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: DPI -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Độ phân giải (DPI)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <TextBlock Text="DPI cao hơn = sắc nét hơn nhưng file nặng hơn." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                    <Slider Value="{x:Bind ViewModel.Dpi, Mode=TwoWay}"
                                            IsEnabled="{x:Bind ViewModel.IsPdfRasterizationEnabled, Mode=OneWay}"
                                            Minimum="50" Maximum="400" StepFrequency="10"
                                            TickFrequency="50" TickPlacement="Outside" />
                                    <TextBlock Text="{x:Bind ViewModel.Dpi, Mode=OneWay}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Border>

                            <!-- Card: JPEG Quality -->
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Chất lượng nén ảnh (1-80)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                    <Slider Value="{x:Bind ViewModel.JpegQuality, Mode=TwoWay}"
                                            IsEnabled="{x:Bind ViewModel.IsPdfRasterizationEnabled, Mode=OneWay}"
                                            Minimum="1" Maximum="80" StepFrequency="1"
                                            TickFrequency="10" TickPlacement="Outside" />
                                    <TextBlock Text="{x:Bind ViewModel.JpegQuality, Mode=OneWay}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- COMMON SETTINGS (Color Mode & Output filename) -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Chế độ màu" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <ComboBox SelectedIndex="{x:Bind ViewModel.ColorModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="RGB (màu gốc)" />
                                    <ComboBoxItem Content="Grayscale (trắng đen)" />
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <CheckBox Content="Gộp theo thư mục (Batch Merge)" IsChecked="{x:Bind ViewModel.BatchMergeMode, Mode=TwoWay}" />
                                <TextBlock Text="Xuất nhiều file PDF độc lập. Tên file được lấy theo tên thư mục chứa file."
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16"
                                Visibility="{x:Bind ViewModel.BatchMergeMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Tên file PDF" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBox Text="{x:Bind ViewModel.OutputFileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="combined-documents.pdf" />
                            </StackPanel>
                        </Border>

                        <!-- Main Action -->
                        <Grid Margin="0,12,0,0">
                            <!-- Start Button -->
                            <Button Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="12"
                                    Command="{x:Bind ViewModel.MergeToPdfCommand}"
                                    Visibility="{x:Bind ViewModel.IsMerging, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE7C3;"/>
                                    <TextBlock Text="Gộp thành PDF" />
                                </StackPanel>
                            </Button>

                            <!-- Processing / Stop Button -->
                            <Button HorizontalAlignment="Stretch" Padding="12"
                                    Command="{x:Bind ViewModel.CancelMergeCommand}"
                                    Visibility="{x:Bind ViewModel.IsMerging, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing IsActive="True" Width="16" Height="16" />
                                    <TextBlock Text="Nhấn để dừng" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
