<Page
    x:Class="FileUtilityHub_WinUI.Features.PdfSplit.PdfSplitPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FileUtilityHub_WinUI.Core.Models"
    xmlns:shared="using:FileUtilityHub_WinUI.Shared.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Toolbar -->
            <RowDefinition Height="Auto" /> <!-- InfoBar -->
            <RowDefinition Height="*" />    <!-- Main Workspace -->
        </Grid.RowDefinitions>

        <!-- 1. Toolbar -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left">
            <AppBarButton Icon="Add" Label="Thêm File" Command="{x:Bind ViewModel.AddFilesCommand}"/>
            <AppBarButton Icon="Folder" Label="Import Folder" Command="{x:Bind ViewModel.ChooseFolderCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Delete" Label="Xóa Đã Chọn" Click="OnRemoveSelectedClick"/>
            <AppBarButton Icon="Clear" Label="Xóa Tất Cả" Command="{x:Bind ViewModel.ClearAllCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="OpenLocal" Label="Mở Thư Mục" Command="{x:Bind ViewModel.OpenOutputCommand}"/>
            
            <AppBarElementContainer VerticalAlignment="Center" Margin="16,0,8,0">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Chọn file &gt;=" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}"/>
                    <NumberBox x:Name="MinSizeNumberBox" Value="1" Minimum="0" SpinButtonPlacementMode="Hidden" Width="80" Height="32"/>
                    <TextBlock Text="MB" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Button Content="Chọn" Click="OnSelectBySizeClick" Height="32"/>
                </StackPanel>
            </AppBarElementContainer>
        </CommandBar>

        <!-- 2. Warning InfoBar -->
        <InfoBar Grid.Row="1"
                 Title="{x:Bind ViewModel.WarningTitle, Mode=OneWay}"
                 Message="{x:Bind ViewModel.WarningMessage, Mode=OneWay}"
                 Severity="{x:Bind ViewModel.WarningSeverity, Mode=OneWay, Converter={StaticResource SeverityToInfoBarConverter}}"
                 IsOpen="{x:Bind ViewModel.HasActiveWarning, Mode=OneWay}"
                 IsClosable="True" />

        <!-- 3. Workspace -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- File List -->
            <Grid Grid.Column="0" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,1,1" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

                <ListView x:Name="FileList" ItemsSource="{x:Bind ViewModel.SplitItems, Mode=OneWay}" SelectionMode="Extended"
                          Visibility="{x:Bind ViewModel.HasFiles, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="MinHeight" Value="56" />
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:PdfSplitItem">
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" /> <!-- Icon -->
                                    <ColumnDefinition Width="*" />    <!-- Name -->
                                    <ColumnDefinition Width="80" />   <!-- Format -->
                                    <ColumnDefinition Width="80" />   <!-- Size -->
                                    <ColumnDefinition Width="80" />   <!-- Pages -->
                                    <ColumnDefinition Width="80" />   <!-- Extracted -->
                                    <ColumnDefinition Width="Auto" /> <!-- Status -->
                                </Grid.ColumnDefinitions>

                                <!-- Icon -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="18"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Border>

                                <!-- Name -->
                                <TextBlock Grid.Column="1" Text="{x:Bind FileName}"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Format -->
                                <TextBlock Grid.Column="2" Text="{x:Bind FormatLabel}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Size -->
                                <TextBlock Grid.Column="3" Text="{x:Bind FormattedOriginalSize}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Pages -->
                                <TextBlock Grid.Column="4" Text="{x:Bind PageCountDisplay, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Extracted count -->
                                <TextBlock Grid.Column="5" Text="{x:Bind ExtractedCount, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Status Badge -->
                                <shared:FileStatusBadge Grid.Column="6"
                                                         Status="{x:Bind Status, Mode=OneWay}"
                                                         StatusLabel="{x:Bind StatusDisplay, Mode=OneWay}"
                                                         VerticalAlignment="Center"
                                                         MinWidth="100" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- DropZone empty state -->
                <shared:DropZoneControl Visibility="{x:Bind ViewModel.HasFiles, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                         DropCommand="{x:Bind ViewModel.HandleDropCommand}" />
            </Grid>

            <!-- Settings Panel -->
            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,1">
                <ScrollViewer Padding="20">
                    <StackPanel Spacing="24">
                        <!-- Header -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Thiết lập tách PDF" Style="{ThemeResource TitleTextBlockStyle}"/>
                            <TextBlock Text="Cấu hình DPI, định dạng và chất lượng ảnh đầu ra." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Card 1: DPI Preset -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Độ phân giải (DPI)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="DPI cao hơn cho ảnh sắc nét hơn nhưng file lớn hơn." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                <ComboBox SelectedIndex="{x:Bind ViewModel.DpiPresetIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Auto (150 DPI)" />
                                    <ComboBoxItem Content="Thấp (96 DPI)" />
                                    <ComboBoxItem Content="Cao (300 DPI)" />
                                    <ComboBoxItem Content="Tùy chỉnh" />
                                </ComboBox>
                                <NumberBox Header="DPI tùy chỉnh" Value="{x:Bind ViewModel.CustomDpi, Mode=TwoWay}"
                                           Minimum="72" Maximum="600" SpinButtonPlacementMode="Inline"
                                           Visibility="{x:Bind ViewModel.ShowCustomDpi, Mode=OneWay}" />
                            </StackPanel>
                        </Border>

                        <!-- Card 2: Output Format -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Định dạng xuất" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Chọn định dạng ảnh đầu ra cho từng trang." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                <ComboBox SelectedIndex="{x:Bind ViewModel.OutputFormatIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="JPEG" />
                                    <ComboBoxItem Content="PNG (lossless)" />
                                    <ComboBoxItem Content="AVIF" />
                                    <ComboBoxItem Content="WebP" />
                                </ComboBox>

                                <!-- JPEG Quality -->
                                <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.ShowJpegQuality, Mode=OneWay}">
                                    <shared:QualityStepperSlider
                                        Value="{x:Bind ViewModel.JpegQuality, Mode=TwoWay}"
                                        Minimum="1" Maximum="100" StepFrequency="5"
                                        LowLabel="Nhẹ hơn" HighLabel="Đẹp hơn" />
                                </StackPanel>

                                <!-- AVIF CRF -->
                                <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.ShowAvifCrf, Mode=OneWay}">
                                    <shared:QualityStepperSlider
                                        Value="{x:Bind ViewModel.AvifCrf, Mode=TwoWay}"
                                        Minimum="0" Maximum="63" StepFrequency="2"
                                        LowLabel="Đẹp hơn" HighLabel="Nhẹ hơn" />
                                </StackPanel>

                                <!-- WebP Quality -->
                                <StackPanel Spacing="4" Visibility="{x:Bind ViewModel.ShowWebPQuality, Mode=OneWay}">
                                    <shared:QualityStepperSlider
                                        Value="{x:Bind ViewModel.WebPQuality, Mode=TwoWay}"
                                        Minimum="0" Maximum="100" StepFrequency="5"
                                        LowLabel="Nhẹ hơn" HighLabel="Đẹp hơn" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Card 3: Action Buttons -->
                        <Grid Margin="0,12,0,0">
                            <!-- Start Button -->
                            <Button Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="12"
                                    Click="OnStartSplitClick"
                                    Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8A9;"/>
                                    <TextBlock Text="Bắt đầu tách" />
                                </StackPanel>
                            </Button>

                            <!-- Cancel Button -->
                            <Button HorizontalAlignment="Stretch" Padding="12"
                                    Command="{x:Bind ViewModel.CancelCommand}"
                                    Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing IsActive="True" Width="16" Height="16" />
                                    <TextBlock Text="Nhấn để dừng" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
