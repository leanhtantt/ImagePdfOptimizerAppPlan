<Page
    x:Class="FileUtilityHub_WinUI.Features.ImageOptimizer.ImageOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FileUtilityHub_WinUI.Core.Models"
    xmlns:shared="using:FileUtilityHub_WinUI.Shared.Controls"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Toolbar -->
            <RowDefinition Height="Auto" /> <!-- InfoBar -->
            <RowDefinition Height="*" />    <!-- Main Workspace -->
        </Grid.RowDefinitions>

        <!-- 1. Toolbar Area with Handoff Actions -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left">
            <AppBarButton Icon="Add" Label="Thêm File" Command="{x:Bind ViewModel.AddFilesCommand}"/>
            <AppBarButton Icon="Folder" Label="Import Folder" Command="{x:Bind ViewModel.ChooseFolderCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Delete" Label="Xóa Đã Chọn" Click="OnRemoveSelectedClick"/>
            <AppBarButton Icon="Clear" Label="Xóa Tất Cả" Command="{x:Bind ViewModel.ClearAllCommand}"/>
            <AppBarSeparator/>

            <!-- Handoff actions (doc 09 section 4) -->
            <AppBarButton Label="Gộp file" Command="{x:Bind ViewModel.SendToMergeCommand}"
                          ToolTipService.ToolTip="Gửi ảnh sang Gộp file / PDF Builder">
                <AppBarButton.Icon><FontIcon Glyph="&#xE8F1;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Label="Gộp và nén" Command="{x:Bind ViewModel.MergeAndCompressCommand}"
                          ToolTipService.ToolTip="Gộp file rồi gửi sang Nén PDF tự động">
                <AppBarButton.Icon><FontIcon Glyph="&#xE74B;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator/>

            <AppBarButton Icon="OpenLocal" Label="Mở Thư Mục Đích" Command="{x:Bind ViewModel.OpenOutputCommand}"/>
        </CommandBar>

        <!-- 2. Warning/Error InfoBar (doc 06 section 5.2) -->
        <InfoBar Grid.Row="1"
                 Title="{x:Bind ViewModel.WarningTitle, Mode=OneWay}"
                 Message="{x:Bind ViewModel.WarningMessage, Mode=OneWay}"
                 Severity="{x:Bind ViewModel.WarningSeverity, Mode=OneWay, Converter={StaticResource SeverityToInfoBarConverter}}"
                 IsOpen="{x:Bind ViewModel.HasActiveWarning, Mode=OneWay}"
                 IsClosable="True" />

        <!-- 3. Workspace Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- File List using ListView -->
            <Grid Grid.Column="0" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,1,1" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

                <!-- ListView with improved row template (doc 06 section 8) -->
                <ListView x:Name="FileList" ItemsSource="{x:Bind ViewModel.ImageItems, Mode=OneWay}" SelectionMode="Extended"
                          SelectionChanged="FileList_SelectionChanged"
                          Tapped="FileList_Tapped"
                          Visibility="{x:Bind ViewModel.HasImages, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="MinHeight" Value="56" />
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ImageItem">
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" /> <!-- Thumbnail placeholder -->
                                    <ColumnDefinition Width="*" />    <!-- Name -->
                                    <ColumnDefinition Width="160" />  <!-- Size comparison -->
                                    <ColumnDefinition Width="60" />   <!-- Savings -->
                                    <ColumnDefinition Width="Auto" /> <!-- Status badge -->
                                </Grid.ColumnDefinitions>

                                <!-- Thumbnail placeholder 40x40 -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <FontIcon Glyph="&#xE8B9;" FontSize="18"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Border>

                                <!-- Name -->
                                <TextBlock Grid.Column="1" Text="{x:Bind FileName}"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Size comparison -->
                                <TextBlock Grid.Column="2" Text="{x:Bind SizeComparison, Mode=OneWay}"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Savings percentage -->
                                <TextBlock Grid.Column="3" Text="{x:Bind SavingsSummary, Mode=OneWay}"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Margin="8,0" />

                                <!-- Status Badge (shared control) -->
                                <shared:FileStatusBadge Grid.Column="4"
                                                         Status="{x:Bind Status, Mode=OneWay}"
                                                         VerticalAlignment="Center"
                                                         MinWidth="100" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- DropZone empty state (shared control) -->
                <shared:DropZoneControl Visibility="{x:Bind ViewModel.HasImages, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                         DropCommand="{x:Bind ViewModel.HandleDropCommand}" />
            </Grid>

            <!-- Settings Panel -->
            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,1">
                <ScrollViewer Padding="20">
                    <StackPanel Spacing="24">
                        <!-- Header -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Thiết lập nén ảnh" Style="{ThemeResource TitleTextBlockStyle}"/>
                            <TextBlock Text="Cấu hình mức độ nén và kích thước đầu ra cho file AVIF." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        
                        <!-- Card 1: CRF using shared QualityStepperSlider -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Chất lượng ảnh (CRF)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Giá trị thấp hơn cho chất lượng cao hơn." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                <shared:QualityStepperSlider
                                    Value="{x:Bind ViewModel.AvifCrf, Mode=TwoWay}"
                                    Minimum="0" Maximum="40" StepFrequency="2"
                                    LowLabel="Đẹp hơn" HighLabel="Nhẹ hơn" />
                            </StackPanel>
                        </Border>
                        
                        <!-- Card 2: Resolution -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Độ phân giải tối đa" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Giảm kích thước cạnh dài nhất nếu ảnh quá lớn." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                <ComboBox SelectedIndex="{x:Bind ViewModel.ResolutionIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Giữ nguyên gốc" />
                                    <ComboBoxItem Content="1920 px (FHD)" />
                                    <ComboBoxItem Content="2048 px (2K)" />
                                    <ComboBoxItem Content="2560 px (QHD)" />
                                </ComboBox>
                            </StackPanel>
                        </Border>
                        
                        <!-- Main Action -->
                        <Grid Margin="0,12,0,0">
                            <!-- Start Button -->
                            <Button Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="12" 
                                    Command="{x:Bind ViewModel.ConvertAvifCommand}"
                                    Visibility="{x:Bind ViewModel.IsConverting, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;"/>
                                    <TextBlock Text="Bắt đầu nén AVIF" />
                                </StackPanel>
                            </Button>

                            <!-- Processing / Stop Button -->
                            <Button HorizontalAlignment="Stretch" Padding="12" 
                                    Command="{x:Bind ViewModel.CancelConversionCommand}"
                                    Visibility="{x:Bind ViewModel.IsConverting, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing IsActive="True" Width="16" Height="16" />
                                    <TextBlock Text="Nhấn để dừng" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
