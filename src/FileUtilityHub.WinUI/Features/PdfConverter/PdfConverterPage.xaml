<Page
    x:Class="FileUtilityHub_WinUI.Features.PdfConverter.PdfConverterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FileUtilityHub_WinUI.Core.Models"
    xmlns:shared="using:FileUtilityHub_WinUI.Shared.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Toolbar -->
            <RowDefinition Height="Auto" /> <!-- InfoBar -->
            <RowDefinition Height="*" />    <!-- Main Workspace -->
        </Grid.RowDefinitions>

        <!-- 1. Toolbar -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left">
            <AppBarButton Icon="Add" Label="Thêm File" Command="{x:Bind ViewModel.AddFilesCommand}"/>
            <AppBarButton Icon="Folder" Label="Import Folder" Command="{x:Bind ViewModel.ChooseFolderCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Delete" Label="Xóa Đã Chọn" Click="OnRemoveSelectedClick"/>
            <AppBarButton Icon="Clear" Label="Xóa Tất Cả" Command="{x:Bind ViewModel.ClearAllCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="OpenLocal" Label="Mở Thư Mục" Click="OnOpenOutputFolderClick"/>
        </CommandBar>

        <!-- 2. Warning/Error InfoBar -->
        <InfoBar Grid.Row="1"
                 Title="{x:Bind ViewModel.WarningTitle, Mode=OneWay}"
                 Message="{x:Bind ViewModel.WarningMessage, Mode=OneWay}"
                 Severity="{x:Bind ViewModel.WarningSeverity, Mode=OneWay, Converter={StaticResource SeverityToInfoBarConverter}}"
                 IsOpen="{x:Bind ViewModel.HasActiveWarning, Mode=OneWay}"
                 IsClosable="True" />

        <!-- 3. Workspace Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- File List (no reorder - order doesn't matter for Convert PDF) -->
            <Grid Grid.Column="0" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,1,1" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

                <ListView x:Name="FileList" ItemsSource="{x:Bind ViewModel.ConvertItems, Mode=OneWay}" SelectionMode="Extended"
                          AllowDrop="True"
                          Visibility="{x:Bind ViewModel.HasFiles, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="MinHeight" Value="56" />
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:PdfConvertItem">
                            <Grid Padding="12,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" /> <!-- Thumbnail -->
                                    <ColumnDefinition Width="*" />    <!-- File name -->
                                    <ColumnDefinition Width="70" />   <!-- Format -->
                                    <ColumnDefinition Width="90" />   <!-- Original size -->
                                    <ColumnDefinition Width="*" />    <!-- Result -->
                                    <ColumnDefinition Width="90" />   <!-- Output size -->
                                    <ColumnDefinition Width="Auto" /> <!-- Status badge -->
                                </Grid.ColumnDefinitions>

                                <!-- Thumbnail placeholder -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="6"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <FontIcon Glyph="&#xE8B9;" FontSize="18"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Border>

                                <!-- File name -->
                                <TextBlock Grid.Column="1" Text="{x:Bind FileName}"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Format category -->
                                <TextBlock Grid.Column="2" Text="{x:Bind FormatCategory}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />

                                <!-- Original size -->
                                <TextBlock Grid.Column="3" Text="{x:Bind FormattedOriginalSize}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />

                                <!-- Result (output name or error) -->
                                <TextBlock Grid.Column="4" Text="{x:Bind ResultDisplay, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Output size -->
                                <TextBlock Grid.Column="5" Text="{x:Bind FormattedOutputSize, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />

                                <!-- Status Badge (shared control) -->
                                <shared:FileStatusBadge Grid.Column="6"
                                                         Status="{x:Bind Status, Mode=OneWay}"
                                                         StatusLabel="{x:Bind StatusDisplay, Mode=OneWay}"
                                                         VerticalAlignment="Center"
                                                         MinWidth="100" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- DropZone empty state -->
                <shared:DropZoneControl Visibility="{x:Bind ViewModel.HasFiles, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                         DropCommand="{x:Bind ViewModel.HandleDropCommand}" />
            </Grid>

            <!-- Settings Panel -->
            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,1">
                <ScrollViewer Padding="20">
                    <StackPanel Spacing="24">
                        <!-- Header -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Convert sang PDF" Style="{ThemeResource TitleTextBlockStyle}"/>
                            <TextBlock Text="Chuyển file hỗn hợp thành PDF riêng cho từng file. Output tạo cạnh file nguồn."
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Card: Color Mode -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Chế độ màu" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <ComboBox SelectedIndex="{x:Bind ViewModel.ColorModeIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Đen trắng" />
                                    <ComboBoxItem Content="RGB (giữ màu gốc)" />
                                </ComboBox>
                                <TextBlock Text="Đen trắng phù hợp tài liệu cần đóng dấu, giúp loại bỏ màu và giảm dung lượng. RGB giữ màu gần file gốc nhưng file thường nặng hơn."
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Card: Fast Mode -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <ToggleSwitch Header="Chế độ nhanh" IsOn="{x:Bind ViewModel.FastMode, Mode=TwoWay}" OnContent="BẬT" OffContent="TẮT"/>
                                <TextBlock Text="Bỏ qua AVIF, giảm DPI (150) và tăng nén JPEG — nhanh hơn 5-10 lần. File output nhỏ gọn, chất lượng vẫn đủ rõ để đọc và in."
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Info card: supported formats -->
                        <InfoBar Severity="Informational" IsOpen="True" IsClosable="False"
                                 Title="Định dạng hỗ trợ"
                                 Message="PDF, Word (.doc/.docx), Excel (.xls/.xlsx), PowerPoint (.ppt/.pptx), và ảnh (JPG, PNG, BMP, TIFF, WebP, AVIF)." />

                        <!-- Convert action -->
                        <StackPanel Spacing="8">
                            <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Text="Chọn một hoặc nhiều dòng rồi nhấn Convert để chỉ xử lý các dòng đã chọn. Nếu không chọn dòng nào, toàn bộ danh sách sẽ được convert." />

                            <!-- Start Button -->
                            <Button Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="12"
                                    Click="OnConvertClick"
                                    Visibility="{x:Bind ViewModel.IsConverting, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8AB;"/>
                                    <TextBlock Text="Convert sang PDF" />
                                </StackPanel>
                            </Button>

                            <!-- Processing / Stop Button -->
                            <Button HorizontalAlignment="Stretch" Padding="12"
                                    Command="{x:Bind ViewModel.CancelConvertCommand}"
                                    Visibility="{x:Bind ViewModel.IsConverting, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing IsActive="True" Width="16" Height="16" />
                                    <TextBlock Text="Nhấn để dừng" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
