<Page
    x:Class="FileUtilityHub_WinUI.Features.DocumentOcr.DocumentOcrPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FileUtilityHub_WinUI.Core.Models"
    xmlns:shared="using:FileUtilityHub_WinUI.Shared.Controls"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Toolbar -->
            <RowDefinition Height="Auto" /> <!-- InfoBar -->
            <RowDefinition Height="*" />    <!-- Main Workspace -->
        </Grid.RowDefinitions>

        <!-- 1. Toolbar -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left">
            <AppBarButton Icon="Add" Label="Thêm File" Command="{x:Bind ViewModel.AddFilesCommand}"/>
            <AppBarButton Icon="Folder" Label="Import Folder" Command="{x:Bind ViewModel.ChooseFolderCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Delete" Label="Xóa Đã Chọn" Click="OnRemoveSelectedClick"/>
            <AppBarButton Icon="Clear" Label="Xóa Tất Cả" Command="{x:Bind ViewModel.ClearAllCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Label="Kiểm tra OCR Server" Command="{x:Bind ViewModel.CheckServerCommand}">
                <AppBarButton.Icon><FontIcon Glyph="&#xE895;"/></AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton Icon="OpenLocal" Label="Mở Thư Mục Output" Command="{x:Bind ViewModel.OpenOutputFolderCommand}"/>
        </CommandBar>

        <!-- 2. Warning/Error InfoBar -->
        <InfoBar Grid.Row="1"
                 Title="{x:Bind ViewModel.WarningTitle, Mode=OneWay}"
                 Message="{x:Bind ViewModel.WarningMessage, Mode=OneWay}"
                 Severity="{x:Bind ViewModel.WarningSeverity, Mode=OneWay, Converter={StaticResource SeverityToInfoBarConverter}}"
                 IsOpen="{x:Bind ViewModel.HasActiveWarning, Mode=OneWay}"
                 IsClosable="True" />

        <!-- 3. Workspace Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- File List -->
            <Grid Grid.Column="0" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,1,1" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

                <ListView x:Name="FileList" ItemsSource="{x:Bind ViewModel.OcrItems, Mode=OneWay}" SelectionMode="Extended"
                          AllowDrop="True"
                          Visibility="{x:Bind ViewModel.HasFiles, Mode=OneWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="MinHeight" Value="56" />
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DocumentOcrItem">
                            <Grid Padding="12,8" ColumnSpacing="12" Background="Transparent" DoubleTapped="FileListItem_DoubleTapped">
                                <Grid.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Mở file" Icon="OpenFile" Click="MenuFlyoutItem_Open_Click" />
                                        <MenuFlyoutItem Text="Mở thư mục" Icon="Folder" Click="MenuFlyoutItem_OpenFolder_Click" />
                                        <MenuFlyoutItem Text="Xóa khỏi danh sách" Icon="Delete" Click="MenuFlyoutItem_Remove_Click" />
                                    </MenuFlyout>
                                </Grid.ContextFlyout>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" /> <!-- Icon -->
                                    <ColumnDefinition Width="*" />    <!-- Name -->
                                    <ColumnDefinition Width="60" />   <!-- Format -->
                                    <ColumnDefinition Width="80" />   <!-- Size -->
                                    <ColumnDefinition Width="*" />    <!-- Result -->
                                    <ColumnDefinition Width="70" />   <!-- Time -->
                                    <ColumnDefinition Width="Auto" /> <!-- Status badge -->
                                </Grid.ColumnDefinitions>

                                <!-- File icon -->
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="16"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Border>

                                <!-- File name -->
                                <TextBlock Grid.Column="1" Text="{x:Bind FileName}"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />

                                <!-- Format -->
                                <TextBlock Grid.Column="2" Text="{x:Bind FormatCategory}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Size -->
                                <TextBlock Grid.Column="3" Text="{x:Bind FormattedOriginalSize}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />

                                <!-- Result -->
                                <TextBlock Grid.Column="4" Text="{x:Bind ResultDisplay, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- Elapsed time -->
                                <TextBlock Grid.Column="5" Text="{x:Bind ElapsedDisplay, Mode=OneWay}"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                <!-- Status Badge -->
                                <shared:FileStatusBadge Grid.Column="6"
                                                         Status="{x:Bind DisplayStatus, Mode=OneWay}"
                                                         StatusLabel="{x:Bind StatusDisplay, Mode=OneWay}"
                                                         VerticalAlignment="Center"
                                                         MinWidth="100" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- DropZone empty state -->
                <shared:DropZoneControl Visibility="{x:Bind ViewModel.HasFiles, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                         DropCommand="{x:Bind ViewModel.HandleDropCommand}" />
            </Grid>

            <!-- Settings Panel -->
            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,1">
                <ScrollViewer Padding="20">
                    <StackPanel Spacing="24">
                        <!-- Header -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="OCR tài liệu" Style="{ThemeResource TitleTextBlockStyle}"/>
                            <TextBlock Text="PDF/Ảnh scan sang Word chỉnh sửa" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <!-- Card: Server Status -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Trạng thái OCR server" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="{x:Bind ViewModel.ServerStatusIcon, Mode=OneWay}" FontSize="20" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.ServerStatusText, Mode=OneWay}"
                                               Style="{ThemeResource BodyTextBlockStyle}" VerticalAlignment="Center"/>
                                </Grid>
                                <Button Content="Kiểm tra lại" Command="{x:Bind ViewModel.CheckServerCommand}"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Border>

                        <!-- Card: Output Description -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Thiết lập đầu ra" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <StackPanel Spacing="4">
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        • Loại bỏ ảnh và con dấu
                                    </TextBlock>
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        • Khổ A4 dọc, tự chuyển ngang cho bảng rộng
                                    </TextBlock>
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        • DOCX sạch, có thể chỉnh sửa
                                    </TextBlock>
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        • Output cùng thư mục file nguồn
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Info: Supported formats -->
                        <InfoBar Severity="Informational" IsOpen="True" IsClosable="False"
                                 Title="Định dạng hỗ trợ"
                                 Message="PDF, JPG, PNG, BMP, TIFF, WebP" />

                        <!-- Main Action -->
                        <Grid Margin="0,12,0,0">
                            <!-- Start Button -->
                            <Button Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="12"
                                    Click="OnOcrClick"
                                    IsEnabled="{x:Bind ViewModel.IsServerReady, Mode=OneWay}"
                                    Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE8D4;"/>
                                    <TextBlock Text="OCR sang Word" />
                                </StackPanel>
                            </Button>

                            <!-- Processing / Stop Button -->
                            <Button HorizontalAlignment="Stretch" Padding="12"
                                    Command="{x:Bind ViewModel.CancelOcrCommand}"
                                    Visibility="{x:Bind ViewModel.IsProcessing, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing IsActive="True" Width="16" Height="16" />
                                    <TextBlock Text="Nhấn để dừng" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
