<Page
    x:Class="FileUtilityHub_WinUI.Features.ImagePdfOptimizer.ImagePdfOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FileUtilityHub.Core.Models"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Toolbar -->
            <RowDefinition Height="*" />    <!-- Main Workspace -->
            <RowDefinition Height="Auto" /> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- 1. Toolbar Area -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" HorizontalAlignment="Left">
            <AppBarButton Icon="Add" Label="Thêm File" Command="{x:Bind ViewModel.AddFilesCommand}"/>
            <AppBarButton Icon="Folder" Label="Import Folder" Command="{x:Bind ViewModel.ChooseFolderCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Delete" Label="Xóa Đã Chọn" Command="{x:Bind ViewModel.RemoveSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=FileList}"/>
            <AppBarButton Icon="Clear" Label="Xóa Tất Cả" Command="{x:Bind ViewModel.ClearAllCommand}"/>
            <AppBarSeparator/>
            <AppBarButton Icon="OpenLocal" Label="Mở Thư Mục Đích" Command="{x:Bind ViewModel.OpenOutputCommand}"/>
        </CommandBar>

        <!-- 2. Workspace Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- File List using ListView -->
            <Grid Grid.Column="0" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,1,1" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <Grid Grid.Row="0" Padding="12,10,32,10" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Background="{ThemeResource LayerFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="116" />
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="File" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Column="1" Text="Đường dẫn" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="16,0,0,0" />
                    <TextBlock Grid.Column="2" Text="Dung lượng" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="16,0,0,0" />
                    <TextBlock Grid.Column="3" Text="Chênh lệch" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="16,0,0,0" />
                    <TextBlock Grid.Column="4" Text="Trạng thái" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                </Grid>

                <ListView x:Name="FileList" Grid.Row="1" ItemsSource="{x:Bind ViewModel.ImageItems, Mode=OneWay}" SelectionMode="Extended">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="MinHeight" Value="44" />
                            <Setter Property="Margin" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ImageItem">
                            <Grid Padding="12,8" ColumnSpacing="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="116" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{x:Bind FileName}" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{x:Bind SourcePath}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="16,0,0,0" />
                                <TextBlock Grid.Column="2" Text="{x:Bind FormattedOriginalSize, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="16,0,0,0" />
                                <TextBlock Grid.Column="3" Text="{x:Bind SavingsSummary, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="16,0,0,0" />

                                <StackPanel Grid.Column="4" Spacing="6" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                                    <Border Background="{Binding Status, Converter={StaticResource ProcessingStatusBrushConverter}}" CornerRadius="12" Padding="8,4" HorizontalAlignment="Stretch">
                                        <TextBlock Text="{x:Bind StatusDisplay, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" Foreground="{ThemeResource FileStatusBadgeTextBrush}" TextTrimming="CharacterEllipsis" />
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="1" Margin="24" Padding="24" CornerRadius="8" BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Top" Visibility="{x:Bind ViewModel.HasImages, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Chưa có file trong danh sách" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock Text="Thêm file hoặc import folder để xem tiến trình nén, dung lượng trước/sau và phần trăm tiết kiệm ngay trên từng dòng." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Settings Panel -->
            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,1">
                <ScrollViewer Padding="20">
                    <StackPanel Spacing="24">
                        <!-- Header -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Thiết lập nén ảnh" Style="{ThemeResource TitleTextBlockStyle}"/>
                            <TextBlock Text="Cấu hình mức độ nén và kích thước đầu ra cho file AVIF." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        
                        <!-- Card 1 -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Chất lượng ảnh (CRF)" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Giá trị thấp hơn cho chất lượng cao hơn." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                <Slider Minimum="0" Maximum="40" Value="{x:Bind ViewModel.AvifCrf, Mode=TwoWay}" StepFrequency="2"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Card 2 -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Độ phân giải tối đa" Style="{ThemeResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="Giảm kích thước cạnh dài nhất nếu ảnh quá lớn." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                                <ComboBox SelectedIndex="{x:Bind ViewModel.ResolutionIndex, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="Giữ nguyên gốc" />
                                    <ComboBoxItem Content="1920 px (FHD)" />
                                    <ComboBoxItem Content="2048 px (2K)" />
                                    <ComboBoxItem Content="2560 px (QHD)" />
                                </ComboBox>
                            </StackPanel>
                        </Border>
                        
                        <!-- Main Action -->
                        <Grid Margin="0,12,0,0">
                            <!-- Start Button -->
                            <Button Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Stretch" Padding="12" 
                                    Command="{x:Bind ViewModel.ConvertAvifCommand}"
                                    Visibility="{x:Bind ViewModel.IsConverting, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;"/>
                                    <TextBlock Text="Bắt đầu nén AVIF" />
                                </StackPanel>
                            </Button>

                            <!-- Processing / Stop Button -->
                            <Button HorizontalAlignment="Stretch" Padding="12" 
                                    Command="{x:Bind ViewModel.CancelConversionCommand}"
                                    Visibility="{x:Bind ViewModel.IsConverting, Mode=OneWay}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ProgressRing IsActive="True" Width="16" Height="16" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                    <TextBlock Text="Nhấn để dừng" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
