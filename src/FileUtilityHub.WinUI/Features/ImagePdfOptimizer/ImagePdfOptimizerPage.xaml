<Page
    x:Class="FileUtilityHub_WinUI.Features.ImagePdfOptimizer.ImagePdfOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Toolbar -->
            <RowDefinition Height="*" />    <!-- Main Workspace -->
            <RowDefinition Height="Auto" /> <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- 1. Toolbar Area -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right">
            <AppBarButton Icon="Add" Label="Thêm File Lẻ" Click="BtnAddFiles_Click"/>
            <AppBarButton Icon="Folder" Label="Import Folder" Click="BtnChooseFolder_Click"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Delete" Label="Xóa Đã Chọn" Click="BtnRemoveSelected_Click"/>
            <AppBarButton Icon="Clear" Label="Xóa Tất Cả" Click="BtnClearAll_Click"/>
            <AppBarSeparator/>
            <AppBarButton Icon="OpenLocal" Label="Mở Thư Mục Đích" Click="BtnOpenOutput_Click"/>
            <AppBarSeparator/>
            <AppBarButton Icon="Play" Label="Bắt đầu nén" Click="BtnConvertAvif_Click" x:Name="BtnConvertAvif"/>
        </CommandBar>

        <!-- 2. Workspace Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="350" />
            </Grid.ColumnDefinitions>

            <!-- File List (Queue) using DataGrid -->
            <Border Grid.Column="0" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,1,1">
                <controls:DataGrid x:Name="FileList" AutoGenerateColumns="False" ItemsSource="{x:Bind _imageItems}" CanUserSortColumns="True">
                    <controls:DataGrid.Columns>
                        <controls:DataGridTextColumn Header="Tên file" Binding="{Binding FileName}" Width="250"/>
                        <controls:DataGridTextColumn Header="Định dạng" Binding="{Binding Format}" Width="80"/>
                        <controls:DataGridTextColumn Header="Dung lượng" Binding="{Binding FormattedOriginalSize}" Width="100"/>
                        <controls:DataGridTextColumn Header="Size đầu ra" Binding="{Binding FormattedOutputSize}" Width="100"/>
                        <controls:DataGridTextColumn Header="Trạng thái" Binding="{Binding Status}" Width="120"/>
                    </controls:DataGrid.Columns>
                </controls:DataGrid>
            </Border>

            <!-- Settings Panel -->
            <Border Grid.Column="1" Background="{ThemeResource LayerFillColorDefaultBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,1">
                <ScrollViewer Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Encoding Settings" FontWeight="SemiBold" FontSize="16"/>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Chất lượng (CRF):" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Slider x:Name="SliderCrf" Minimum="0" Maximum="40" Value="24" StepFrequency="2"/>
                        </StackPanel>
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="Độ phân giải tối đa:" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <ComboBox x:Name="ComboResolution" SelectedIndex="0" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Giữ nguyên gốc" Tag="0"/>
                                <ComboBoxItem Content="1920 px (FHD)" Tag="1920"/>
                                <ComboBoxItem Content="2048 px (2K)" Tag="2048"/>
                                <ComboBoxItem Content="2560 px (QHD)" Tag="2560"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 3. Status Bar (Bottom) -->
        <Border Grid.Row="2" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatusMessage" Text="Sẵn sàng." VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <ProgressBar x:Name="ProgressAvif" Grid.Column="1" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Page>
