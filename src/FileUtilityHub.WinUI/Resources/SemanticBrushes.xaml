<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="FileStatusPendingBrush" Color="#6B7280" />
    <SolidColorBrush x:Key="FileStatusProcessingBrush" Color="#2563EB" />
    <SolidColorBrush x:Key="FileStatusSuccessBrush" Color="#0F7B0F" />
    <SolidColorBrush x:Key="FileStatusWarningBrush" Color="#B45309" />
    <SolidColorBrush x:Key="FileStatusErrorBrush" Color="#C42B1C" />
    <SolidColorBrush x:Key="FileStatusSkippedBrush" Color="#64748B" />
    <SolidColorBrush x:Key="FileStatusBadgeTextBrush" Color="#FFFFFF" />

</ResourceDictionary>
