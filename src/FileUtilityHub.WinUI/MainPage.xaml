<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FileUtilityHub_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FileUtilityHub_WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        This is the main content area of your application.
        Add your UI elements here — for example, controls, layouts, and data-bound views.
        Use 'dotnet new winui-page' to create additional pages and navigate to them via
        the Frame in MainWindow (RootFrame).
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <NavigationView Grid.Row="0" x:Name="NavView" SelectionChanged="NavView_SelectionChanged" IsBackButtonVisible="Collapsed">
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Pictures" Content="Image PDF Optimizer" Tag="ImagePdfOptimizer" />
                <NavigationViewItem Icon="Document" Content="PDF Compressor" Tag="PdfCompressor" />
                <NavigationViewItem Icon="Copy" Content="PDF Converter" Tag="PdfConverter" />
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- Global Status Bar -->
        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <!-- Left: Status Message -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind StatusService.ItemCountText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind StatusService.StatusMessage, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </StackPanel>
                
                <!-- Right: Progress Bar & Percentage -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" Visibility="{x:Bind StatusService.IsProcessing, Mode=OneWay}">
                    <ProgressBar Minimum="0" Maximum="{x:Bind StatusService.ProgressMaximum, Mode=OneWay}" Value="{x:Bind StatusService.ProgressValue, Mode=OneWay}" Width="200" VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind StatusService.ProgressPercentageText, Mode=OneWay}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Width="45" TextAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
