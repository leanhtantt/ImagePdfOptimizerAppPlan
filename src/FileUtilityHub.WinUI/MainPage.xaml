<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FileUtilityHub_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FileUtilityHub_WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        This is the main content area of your application.
        Add your UI elements here — for example, controls, layouts, and data-bound views.
        Use 'dotnet new winui-page' to create additional pages and navigate to them via
        the Frame in MainWindow (RootFrame).
    -->
    <Grid>
        <NavigationView x:Name="NavView" SelectionChanged="NavView_SelectionChanged" IsBackButtonVisible="Collapsed">
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Pictures" Content="Image PDF Optimizer" Tag="ImagePdfOptimizer" />
                <NavigationViewItem Icon="Document" Content="PDF Compressor" Tag="PdfCompressor" />
                <NavigationViewItem Icon="Copy" Content="PDF Converter" Tag="PdfConverter" />
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Page>
