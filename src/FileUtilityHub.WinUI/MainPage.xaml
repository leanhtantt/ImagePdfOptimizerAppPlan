<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FileUtilityHub_WinUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FileUtilityHub_WinUI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Global Warning -->
            <RowDefinition Height="*" />    <!-- NavigationView -->
            <RowDefinition Height="Auto" /> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Global Warning: FFmpeg Missing -->
        <InfoBar Grid.Row="0"
                 x:Name="FfmpegWarningBar"
                 Title="Thiếu FFmpeg"
                 Message="Bản cài đặt thiếu thành phần xử lý. Một số tính năng sẽ không hoạt động."
                 Severity="Warning"
                 IsOpen="{x:Bind StatusService.IsFfmpegMissing, Mode=OneWay}"
                 IsClosable="False" />

        <!-- Suite Navigation -->
        <NavigationView Grid.Row="1" x:Name="NavView" SelectionChanged="NavView_SelectionChanged" IsBackButtonVisible="Collapsed">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Tối ưu ảnh" Tag="ImageOptimizer">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8B9;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Gộp file" Tag="FileMergePdfBuilder">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8F1;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Nén PDF" Tag="PdfCompressor">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE7C3;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Convert PDF" Tag="PdfConverter">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8AB;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Tách PDF" Tag="PdfSplit">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8A9;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="OCR tài liệu" Tag="DocumentOcr">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE8D4;"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- Global Status Bar -->
        <Border Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                
                <!-- Left: Status Message -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind StatusService.ItemCountText, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind StatusService.StatusMessage, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                </StackPanel>
                
                <!-- Right: Progress Bar & Percentage -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" Visibility="{x:Bind StatusService.IsProcessing, Mode=OneWay}">
                    <ProgressBar Minimum="0" Maximum="{x:Bind StatusService.ProgressMaximum, Mode=OneWay}" Value="{x:Bind StatusService.ProgressValue, Mode=OneWay}" Width="200" VerticalAlignment="Center" />
                    <TextBlock Text="{x:Bind StatusService.ProgressPercentageText, Mode=OneWay}" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Width="45" TextAlignment="Right" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
